  lastQOTDResponse:
    questionId: 283
    questionText: 'Is there a problem with this code?

      <p>private void SetCameraFollowFunc(Func<Vector3>
      cameraFollowFunc) { }</p>

      <p>SetCameraFollowFunc(() => new Vector3(1,
      0, 0));</p>'
    answerA: No
    answerB: 'Should be: SetCameraFollowFunc(() => return new Vector3(1, 0, 0));'
    answerC: 'Should be: SetCameraFollowFunc((Vector3(1, 0, 0)) => { });'
    answerD: 
