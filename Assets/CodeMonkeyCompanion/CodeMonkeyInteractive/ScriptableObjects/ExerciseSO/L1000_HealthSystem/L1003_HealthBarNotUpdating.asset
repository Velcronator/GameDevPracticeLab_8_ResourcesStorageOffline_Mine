  m_Script: {fileID: 11500000, guid: 1e0d8dd5b8f33e34b965fec3f1ff8d3e, type: 3}
  m_Name: L1003_HealthBarNotUpdating
  m_EditorClassIdentifier: 
  exerciseNumber: 03
  exerciseName: HealthBarNotUpdating
  exerciseTitle: Health Bar not Updating
  videoWalkthroughUrl: https://unitycodemonkey.teachable.com/courses/problem-solving/lectures/63458626
  exerciseText: Health Bar should update
  hintText: When is the HealthBar script supposed to update?
  solutionText: 'Event OnHealthAmountChanged is not being fired on the Health System,
    therefore the HealthBar script never knows the amount changed so it never updates.

    Fire
    off the event whenever the healthAmount changes to fix it.'
