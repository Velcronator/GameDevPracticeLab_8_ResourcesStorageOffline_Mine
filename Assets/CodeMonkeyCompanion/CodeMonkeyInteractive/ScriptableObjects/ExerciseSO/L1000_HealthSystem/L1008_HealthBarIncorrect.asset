  m_Script: {fileID: 11500000, guid: 1e0d8dd5b8f33e34b965fec3f1ff8d3e, type: 3}
  m_Name: L1008_HealthBarIncorrect
  m_EditorClassIdentifier: 
  exerciseNumber: 08
  exerciseName: HealthBarIncorrect
  exerciseTitle: Health Bar Incorrect
  videoWalkthroughUrl: https://unitycodemonkey.teachable.com/courses/problem-solving/lectures/63458632
  exerciseText: Health Bar not displaying correctly
  hintText: int / int = int
  solutionText: 'Function GetHealthAmountNormalized(); is doing int math, and when
    you divide an int by another int you get an int. In order to get a float result
    you need to cast at least one of the values into a float, like so

    return
    (float)healthAmount / healthAmountMax;'
